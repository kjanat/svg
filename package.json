{
	"name": "@kjanat/svg-grammars",
	"version": "0.0.0",
	"private": true,
	"description": "Bun workspace for the tree-sitter SVG grammar and its injected sub-grammars",
	"license": "MIT OR Apache-2.0",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"workspaces": ["grammars/*", "scripts"],
	"scripts": {
		"fmt": "dprint fmt",
		"fmt:update": "dprint config update -yr",
		"lint": "bun run --filter '*' lint",
		"prepare": "bun run --filter '*' prepare",
		"postinstall": "bun run --filter '*' postinstall"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/deno": "catalog:",
		"runner-run": "catalog:",
		"tree-sitter": "catalog:"
	},
	"packageManager": "bun@1.3.14",
	"volta": {
		"node": "26.4.0",
		"npm": "11.17.0"
	},
	"catalog": {
		"@biomejs/biome": "^2.5.3",
		"@types/bun": "^1.3",
		"@types/deno": "^2.7.0",
		"dprint": "^0.55.1",
		"node-addon-api": "^8.8",
		"node-gyp": "^13",
		"node-gyp-build": "^4.8",
		"prebuildify": "^6",
		"runner-run": "^0.19.1",
		"tree-sitter": "^0.25.0",
		"tree-sitter-cli": "^0.26.9",
		"typescript": "^6"
	},
	"patchedDependencies": {
		"tree-sitter@0.25.0": "patches/tree-sitter@0.25.0.patch"
	}
}
