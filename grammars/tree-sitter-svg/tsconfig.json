{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"types": ["bun", "tree-sitter-cli/dsl"]
	},
	"include": ["bindings/node", "test", "grammar.js"]
}
