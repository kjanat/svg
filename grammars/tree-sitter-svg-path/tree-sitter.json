{
	"$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
	"grammars": [
		{
			"name": "svg_path",
			"camelcase": "SvgPath",
			"title": "SVG Path Data",
			"scope": "source.svg_path",
			"injection-regex": "^svg_path$",
			"file-types": ["svgpath"],
			"path": ".",
			"external-files": ["./src/scanner.c"],
			"highlights": ["queries/highlights.scm"],
			"textobjects": ["queries/textobjects.scm"]
		}
	],
	"metadata": {
		"version": "0.0.1",
		"license": "MIT",
		"authors": [{ "name": "Kaj Kowalski", "email": "info@kajkowalski.nl" }]
	},
	"bindings": {
		"c": false,
		"go": false,
		"node": false,
		"python": false,
		"rust": false,
		"swift": false,
		"kotlin": false,
		"zig": false
	}
}
